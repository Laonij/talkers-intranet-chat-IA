PORT=8080
BASE_URL=http://localhost:8080
JWT_SECRET=troque-por-um-segredo-grande

# Persistência: local = data | Render = /data
DATA_DIR=data

# Base interna: local = kb ou caminho do Drive sincronizado | Render = /data/kb
INDEX_FOLDER=kb

# OpenAI (opcional): coloque como ENV no servidor (NUNCA no front-end)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Drive Sync (opcional - requer API + Service Account)
DRIVE_FOLDER_ID=
DRIVE_SERVICE_ACCOUNT_JSON=

AUTO_SEED_ON_BOOT=false
AUTO_INDEX_ON_BOOT=false
